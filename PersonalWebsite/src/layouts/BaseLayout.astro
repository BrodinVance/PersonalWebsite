---
import SEO from '../components/SEO.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// Preload the three above-the-fold faces (latin subsets) so the browser
// fetches them alongside the CSS instead of after parsing it. The ?url
// imports resolve to the same hashed assets the Fontsource CSS references.
import marcellusUrl from '@fontsource/marcellus/files/marcellus-latin-400-normal.woff2?url';
import literataUrl from '@fontsource-variable/literata/files/literata-latin-wght-normal.woff2?url';
import splineMonoUrl from '@fontsource-variable/spline-sans-mono/files/spline-sans-mono-latin-wght-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  wide?: boolean;
  /** Float the nav over a full-bleed hero (home page's blue-hour scene). */
  bleed?: boolean;
}

const { title, description, image, article, wide = false, bleed = false } = Astro.props;

// Gutter stars for the ambient layer — deterministic PRNG (same trick as
// HeroScene) so every build renders the identical sky.
function mulberry32(seed: number) {
  return function () {
    let t = (seed += 0x6d2b79f5);
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(18850623); // Lake Louise chalet era, why not

interface GutterStar {
  left: number;
  top: number;
  o: number;
  twinkle: boolean;
  delay: number;
}

// Alternate gutters; tops are % of page height, so any page length reads as
// a random scatter. The hero (opaque) simply covers whichever fall behind it.
const gutterStars: GutterStar[] = Array.from({ length: 14 }, (_, i) => ({
  left: i % 2 === 0 ? +(0.6 + rand() * 3.4).toFixed(2) : +(96 + rand() * 3.4).toFixed(2),
  top: +(4 + rand() * 91).toFixed(2),
  o: +(0.12 + rand() * 0.16).toFixed(2),
  twinkle: i % 4 === 0,
  delay: +(rand() * 5).toFixed(2),
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" as="font" type="font/woff2" href={marcellusUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={literataUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={splineMonoUrl} crossorigin />
    <SEO title={title} description={description} image={image} article={article} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <!-- the night behind the content: lamplight pools + gutter stars -->
    <div class="ambient" aria-hidden="true">
      <span class="pool p1"></span>
      <span class="pool p2"></span>
      <span class="pool p3"></span>
      {gutterStars.map((s) => (
        <span
          class:list={['star', { tw: s.twinkle }]}
          style={`left: ${s.left}%; top: ${s.top}%; --so: ${s.o};${s.twinkle ? ` --td: ${s.delay}s;` : ''}`}
        ></span>
      ))}
    </div>

    <Nav bleed={bleed} />
    <main id="main" class:list={[{ wide }]}>
      <slot />
    </main>
    <Footer />

    <script>
      // Copy buttons on code blocks. Progressive: no clipboard API, no button.
      // Each pre is wrapped in a frame so the button stays put when the code
      // scrolls horizontally.
      (function () {
        if (!navigator.clipboard) return;
        document.querySelectorAll<HTMLPreElement>('pre.astro-code').forEach((pre) => {
          const frame = document.createElement('div');
          frame.className = 'code-frame';
          pre.replaceWith(frame);
          frame.appendChild(pre);

          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'code-copy';
          btn.textContent = 'Copy';
          btn.setAttribute('aria-label', 'Copy code to clipboard');
          frame.appendChild(btn);

          let timer: number | undefined;
          btn.addEventListener('click', async () => {
            const code = pre.querySelector('code');
            try {
              await navigator.clipboard.writeText(code?.innerText ?? pre.innerText);
              btn.textContent = 'Copied';
              btn.classList.add('done');
              window.clearTimeout(timer);
              timer = window.setTimeout(() => {
                btn.textContent = 'Copy';
                btn.classList.remove('done');
              }, 2000);
            } catch {
              btn.textContent = 'Copy failed';
            }
          });
        });
      })();
    </script>

    <script>
      // Reveal-on-scroll. Content ships visible; we only arm (hide-then-reveal)
      // when JS runs AND motion is allowed, so prerender/no-JS/reduced-motion
      // never gate content behind a transition that might not fire.
      (function () {
        const els = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
        if (!els.length || !('IntersectionObserver' in window)) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        els.forEach((el) => el.classList.add('reveal-armed'));
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('reveal-in');
                io.unobserve(e.target);
                // Once the entrance (plus row stagger) finishes, drop the reveal
                // classes so row hover transitions return to their base timing.
                setTimeout(() => {
                  e.target.classList.remove('reveal-armed', 'reveal-in');
                }, 1400);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    padding: 0.5rem 1rem;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    z-index: var(--z-skip);
    border-radius: 2px;
    transition: top 0.2s;
  }

  .skip-link:focus {
    top: 1rem;
  }
</style>
