---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Editor from '../../components/admin/Editor.tsx';
---

<BaseLayout title="Editor" description="Site editor">
  <script is:inline>
    // Mark this browser as the site owner so ReadBeacon never counts it.
    try { localStorage.setItem('bv-admin', '1'); } catch {}
  </script>
  <div class="admin-shell">
    <Editor client:only="react" />
  </div>
</BaseLayout>

<style>
  .admin-shell {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  @media (max-width: 700px) {
    .admin-shell {
      padding: 0 1rem;
    }
  }
</style>
