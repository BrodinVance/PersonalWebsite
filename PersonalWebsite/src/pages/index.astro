---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroScene from '../components/HeroScene.astro';
import { TOPIC_LABELS } from '../lib/topics';
import { vtName } from '../lib/vt';

const allPosts = (
  await getCollection('writing', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestPosts = allPosts.slice(0, 4);
const newestPost = allPosts[0];

const featuredProjects = (
  await getCollection('projects', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  )
)
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.order - a.data.order);

function formatDate(date: Date) {
  return date.toISOString().slice(0, 10).replace(/-/g, '·');
}

const STATUS_LABELS: Record<string, string> = {
  building: 'Building',
  planned: 'Planned',
  ongoing: 'Ongoing',
  shipped: 'Shipped',
};
---

<BaseLayout
  title="Brodin Vance"
  description="Honours Math student at the University of Waterloo. I build games and software, cook more than is reasonable, and write here about whatever I'm learning."
  bleed
>
  <HeroScene>
    <h1 class="fx d1">Brodin Vance</h1>
    <p class="lede fx d2">
      Honours Mathematics Student at University of Waterloo. I build games and software,
      cook more than is reasonable, and write here about whatever I&rsquo;m learning
      &mdash; lately, mostly <em>quantum mechanics</em>.
    </p>
    <a class="cue fx d4" href="#currently">The log &darr;</a>
  </HeroScene>

  <div class="wrap">

    <section class="currently fx d3" id="currently">
      <span class="label">Currently</span>
      <ul>
        <li><span>Heading into <b>Honours Math</b> at the University of Waterloo this fall</span></li>
      </ul>
    </section>

    {latestPosts.length > 0 && (
      <section class="block rule-aurora" id="writing" data-reveal>
        {newestPost && (
          <span class="ghost-year" aria-hidden="true">&rsquo;{String(newestPost.data.date.getFullYear()).slice(-2)}</span>
        )}
        <div class="head">
          <h2>Writing</h2>
          {newestPost && (
            <a class="meta-link" href={`/writing/${newestPost.id}`}>
              Read the latest &rarr;
            </a>
          )}
        </div>

        <div class="log">
          {latestPosts.map((post) => (
            <article class="entry">
              <div class="side">
                <time datetime={post.data.date.toISOString()} class="date">{formatDate(post.data.date)}</time>
                {post.data.topics[0] && (
                  <a class="topic" href={`/writing/topics/${post.data.topics[0]}`}>
                    {TOPIC_LABELS[post.data.topics[0]]}
                  </a>
                )}
              </div>
              <a href={`/writing/${post.id}`}>
                <div>
                  <h3 style={`view-transition-name: ${vtName('post', post.id)}`}>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                </div>
              </a>
            </article>
          ))}
        </div>

        <div class="section-footer">
          <a class="all-link" href="/writing">All writing &rarr;</a>
        </div>
      </section>
    )}

    {featuredProjects.length > 0 && (
      <section class="block rule-aurora" id="projects" data-reveal>
        <div class="head">
          <h2>Projects</h2>
          <a class="meta-link" href="/projects">All projects &rarr;</a>
        </div>

        <div class="proj">
          {featuredProjects.map((project) => (
            <article
              class:list={['prow', { 'has-accent': project.data.accent }]}
              style={project.data.accent ? `--accent: ${project.data.accent}; --accent-dim: ${project.data.accent};` : undefined}
            >
              <div class="ptop">
                <a href={`/projects/${project.id}`}>
                  <h3 style={`view-transition-name: ${vtName('proj', project.id)}`}>{project.data.title}</h3>
                </a>
                <span class:list={['status', project.data.status]}>
                  {STATUS_LABELS[project.data.status]}
                </span>
                {project.data.stack.length > 0 && (
                  <span class="stack">{project.data.stack.join(' · ')}</span>
                )}
              </div>
              <p>{project.data.description}</p>
            </article>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  /* hero type on the sky — inscriptional caps, like the plaque at the lodge */
  h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.5rem, 8.5vw, 5.4rem);
    line-height: 1.06;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.8rem;
  }

  /* a short engraved rule under the name */
  h1::after {
    content: '';
    display: block;
    width: 3.5rem;
    height: 2px;
    margin-top: 1.4rem;
    background: var(--accent);
    border-radius: 1px;
  }

  .lede {
    font-size: clamp(1.1rem, 2.4vw, 1.25rem);
    line-height: 1.6;
    color: var(--ink);
    max-width: var(--measure);
  }

  .lede em {
    font-style: italic;
    color: var(--accent);
  }

  .cue {
    display: inline-block;
    margin-top: 3rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    transition: color var(--dur-fast);
  }

  .cue:hover,
  .cue:focus-visible {
    color: var(--accent);
  }

  .cue:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 1px;
  }

  /* the field note below the scene — a raised frost panel, lit from within */
  .currently {
    margin-top: 2.75rem;
    padding: 1.5rem 1.75rem 1.6rem;
    max-width: var(--measure);
    background: var(--bg-raise);
    border: 1px solid var(--line-soft);
    border-radius: 4px;
  }

  .currently .label {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    text-shadow: 0 0 14px color-mix(in oklab, var(--accent) 45%, transparent);
    display: block;
    margin-bottom: 1rem;
  }

  .currently ul {
    list-style: none;
    display: grid;
    gap: 0.7rem;
  }

  .currently li {
    display: flex;
    gap: 0.85rem;
    font-size: 1rem;
    color: var(--ink-dim);
    line-height: 1.45;
  }

  .currently li::before {
    content: "·";
    color: var(--accent-dim);
    flex: none;
    font-size: 1.15em;
  }

  .currently li b {
    color: var(--ink);
    font-weight: 500;
  }

  .currently li b.brine {
    color: var(--brine);
  }

  /* section frame — the top rule is the global aurora hairline (.rule-aurora) */
  .block {
    padding: 4.25rem 0;
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2.25rem;
    gap: 1rem;
  }

  /* display-scale section titles with the engraved amber tick */
  h2 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.7rem, 4.5vw, 2.2rem);
    letter-spacing: 0.01em;
  }

  h2::after {
    content: '';
    display: block;
    width: 2.5rem;
    height: 2px;
    margin-top: 0.55rem;
    background: var(--accent);
    border-radius: 1px;
  }

  .meta-link {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    transition: color 0.2s;
  }

  .meta-link:hover,
  .meta-link:focus-visible {
    color: var(--accent);
  }

  .meta-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 1px;
  }

  .section-footer {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line-soft);
  }

  .all-link {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .all-link:hover,
  .all-link:focus-visible {
    color: var(--accent);
  }

  .all-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 1px;
  }

</style>
