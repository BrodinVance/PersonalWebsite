---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { TOPICS } from '../../../content.config';
import { TOPIC_LABELS } from '../../../lib/topics';
import type { Topic } from '../../../content.config';

export async function getStaticPaths() {
  const allPosts = await getCollection('writing', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );

  return TOPICS.map((topic) => ({
    params: { topic },
    props: {
      posts: allPosts
        .filter((p) => p.data.topics.includes(topic))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
      label: TOPIC_LABELS[topic],
    },
  }));
}

const { topic } = Astro.params as { topic: Topic };
const { posts, label } = Astro.props;

function formatDate(date: Date) {
  return date.toISOString().slice(0, 10).replace(/-/g, '·');
}
---

<BaseLayout
  title={`${label} — Writing`}
  description={`Posts tagged ${label} on Brodin Vance's site.`}
>
  <div class="wrap">
    <section class="writing-section">
      <div class="head">
        <h1>{label}</h1>
        <a class="back" href="/writing">← All writing</a>
      </div>

      <div class="log">
        {posts.map((post) => (
          <article class="entry">
            <div class="side">
              <span class="date">{formatDate(post.data.date)}</span>
            </div>
            <a href={`/writing/${post.id}`}>
              <div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
              </div>
            </a>
          </article>
        ))}
        {posts.length === 0 && (
          <p class="empty">Nothing here yet.</p>
        )}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .writing-section {
    padding: 3.4rem 0;
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    gap: 1rem;
  }

  h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 6vw, 2.6rem);
    letter-spacing: 0.01em;
  }

  h1::after {
    content: '';
    display: block;
    width: 2.5rem;
    height: 2px;
    margin-top: 0.55rem;
    background: var(--accent);
    border-radius: 1px;
  }

  .back {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .back:hover,
  .back:focus-visible {
    color: var(--accent);
  }

  .back:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 1px;
  }

  .empty {
    color: var(--ink-faint);
    font-family: var(--mono);
    font-size: 0.85rem;
    padding: 2rem 0;
  }
</style>
