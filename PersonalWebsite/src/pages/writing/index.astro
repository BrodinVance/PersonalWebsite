---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOPICS } from '../../content.config';
import { TOPIC_LABELS } from '../../lib/topics';
import { vtName } from '../../lib/vt';

const posts = (
  await getCollection('writing', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toISOString().slice(0, 10).replace(/-/g, '·');
}
---

<BaseLayout title="Writing" description="Notes and essays on quantum mechanics, math, game development, and cooking.">
  <div class="wrap">
    <section class="writing-section">
      {posts[0] && (
        <span class="ghost-year" aria-hidden="true">&rsquo;{String(posts[0].data.date.getFullYear()).slice(-2)}</span>
      )}
      <div class="head">
        <h1>Writing</h1>
        <span class="meta">Weekly · notes &amp; essays</span>
      </div>

      <div class="filters" id="filters" role="group" aria-label="Filter by topic">
        <button class="chip on" data-topic="all" aria-pressed="true">All</button>
        {TOPICS.map((topic) => (
          <button class="chip" data-topic={topic} aria-pressed="false">
            {TOPIC_LABELS[topic]}
          </button>
        ))}
      </div>
      <div role="status" aria-live="polite" id="filter-status" class="sr-only"></div>

      <div class="log" id="log">
        {posts.map((post) => (
          <article class="entry" data-topics={post.data.topics.join(' ')}>
            <div class="side">
              <time datetime={post.data.date.toISOString()} class="date">{formatDate(post.data.date)}</time>
              {post.data.topics[0] && (
                <a class="topic" href={`/writing/topics/${post.data.topics[0]}`}>
                  {TOPIC_LABELS[post.data.topics[0]]}
                </a>
              )}
            </div>
            <a href={`/writing/${post.id}`}>
              <div>
                <h2 style={`view-transition-name: ${vtName('post', post.id)}`}>{post.data.title}</h2>
                <p>{post.data.description}</p>
              </div>
            </a>
          </article>
        ))}
      </div>
      <p class="empty" id="filter-empty">No posts under this topic yet.</p>
    </section>
  </div>
</BaseLayout>

<script>
  (function () {
    const filters = document.getElementById('filters');
    const entries = Array.from(document.querySelectorAll<HTMLElement>('#log .entry'));
    const statusEl = document.getElementById('filter-status');
    const emptyEl = document.getElementById('filter-empty');
    if (!filters) return;

    filters.addEventListener('click', function (e) {
      const btn = (e.target as Element).closest<HTMLButtonElement>('.chip');
      if (!btn) return;
      const topic = btn.getAttribute('data-topic');

      filters.querySelectorAll('.chip').forEach((c) => {
        c.classList.remove('on');
        c.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('on');
      btn.setAttribute('aria-pressed', 'true');

      let visibleCount = 0;
      entries.forEach((entry) => {
        const topics = entry.getAttribute('data-topics') ?? '';
        const show = topic === 'all' || topics.split(' ').includes(topic ?? '');
        if (show) {
          visibleCount++;
          entry.style.display = '';
          requestAnimationFrame(() => entry.classList.remove('hidden'));
        } else {
          entry.classList.add('hidden');
          entry.addEventListener('transitionend', () => {
            if (entry.classList.contains('hidden')) entry.style.display = 'none';
          }, { once: true });
        }
      });

      if (emptyEl) emptyEl.classList.toggle('show', visibleCount === 0);

      if (statusEl) {
        statusEl.textContent = topic === 'all'
          ? `Showing all ${entries.length} posts`
          : visibleCount === 0
            ? 'No posts under this topic yet'
            : `Showing ${visibleCount} of ${entries.length} posts`;
      }
    });
  })();
</script>

<style>
  .writing-section {
    position: relative; /* anchors the ghost year numeral */
    padding: 3.4rem 0;
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    gap: 1rem;
  }

  h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 6vw, 2.6rem);
    letter-spacing: 0.01em;
  }

  h1::after {
    content: '';
    display: block;
    width: 2.5rem;
    height: 2px;
    margin-top: 0.55rem;
    background: var(--accent);
    border-radius: 1px;
  }

  .meta {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  /* filter chips */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.8rem;
  }

  .chip {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    padding: 0.34rem 0.7rem;
    border: 1px solid var(--line);
    border-radius: 2px;
    color: var(--ink-dim);
    cursor: pointer;
    background: transparent;
    transition: all 0.2s ease;
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
  }

  .chip:hover {
    border-color: var(--ink-faint);
    color: var(--ink);
  }

  .chip:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .chip.on {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 8%, transparent);
  }

  /* Filter transitions layer onto the shared .entry system in global.css. */
  .entry {
    transition: opacity 0.25s ease, background var(--dur-fast) ease;
  }

  .entry.hidden {
    opacity: 0;
  }

  /* Shown when a topic filter matches nothing. */
  .empty {
    display: none;
    padding: 2.5rem 0;
    font-family: var(--mono);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--ink-faint);
  }

  .empty.show {
    display: block;
  }
</style>
