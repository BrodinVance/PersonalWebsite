---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOPICS } from '../../content.config';
import { TOPIC_LABELS } from '../../lib/topics';

const posts = (
  await getCollection('writing', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toISOString().slice(0, 10).replace(/-/g, '·');
}
---

<BaseLayout title="Writing" description="Notes and essays on quantum mechanics, math, game development, and cooking.">
  <div class="wrap">
    <section class="writing-section">
      <div class="head">
        <h1>Writing</h1>
        <span class="meta">Weekly · notes &amp; essays</span>
      </div>

      <div class="filters" id="filters" role="group" aria-label="Filter by topic">
        <button class="chip on" data-topic="all" aria-pressed="true">All</button>
        {TOPICS.map((topic) => (
          <button class="chip" data-topic={topic} aria-pressed="false">
            {TOPIC_LABELS[topic]}
          </button>
        ))}
      </div>
      <div role="status" aria-live="polite" id="filter-status" class="sr-only"></div>

      <div class="log" id="log">
        {posts.map((post) => (
          <article class="entry" data-topics={post.data.topics.join(' ')}>
            <div class="side">
              <time datetime={post.data.date.toISOString()} class="date">{formatDate(post.data.date)}</time>
              {post.data.topics[0] && (
                <a class="topic" href={`/writing/topics/${post.data.topics[0]}`}>
                  {TOPIC_LABELS[post.data.topics[0]]}
                </a>
              )}
            </div>
            <a href={`/writing/${post.id}`}>
              <div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  (function () {
    const filters = document.getElementById('filters');
    const entries = Array.from(document.querySelectorAll<HTMLElement>('#log .entry'));
    const statusEl = document.getElementById('filter-status');
    if (!filters) return;

    filters.addEventListener('click', function (e) {
      const btn = (e.target as Element).closest<HTMLButtonElement>('.chip');
      if (!btn) return;
      const topic = btn.getAttribute('data-topic');

      filters.querySelectorAll('.chip').forEach((c) => {
        c.classList.remove('on');
        c.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('on');
      btn.setAttribute('aria-pressed', 'true');

      let visibleCount = 0;
      entries.forEach((entry) => {
        const topics = entry.getAttribute('data-topics') ?? '';
        const show = topic === 'all' || topics.split(' ').includes(topic ?? '');
        if (show) {
          visibleCount++;
          entry.style.display = '';
          requestAnimationFrame(() => entry.classList.remove('hidden'));
        } else {
          entry.classList.add('hidden');
          entry.addEventListener('transitionend', () => {
            if (entry.classList.contains('hidden')) entry.style.display = 'none';
          }, { once: true });
        }
      });

      if (statusEl) {
        statusEl.textContent = topic === 'all'
          ? `Showing all ${entries.length} posts`
          : `Showing ${visibleCount} of ${entries.length} posts`;
      }
    });
  })();
</script>

<style>
  .writing-section {
    padding: 3.4rem 0;
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    gap: 1rem;
  }

  h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.5rem;
    letter-spacing: -0.01em;
  }

  .meta {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  /* filter chips */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.8rem;
  }

  .chip {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    padding: 0.34rem 0.7rem;
    border: 1px solid var(--line);
    border-radius: 2px;
    color: var(--ink-dim);
    cursor: pointer;
    background: transparent;
    transition: all 0.2s ease;
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
  }

  .chip:hover {
    border-color: var(--ink-faint);
    color: var(--ink);
  }

  .chip:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .chip.on {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(203, 142, 66, 0.06);
  }

  /* log */
  .log {
    display: grid;
    gap: 0;
  }

  .entry {
    position: relative;
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: 1.4rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--line-soft);
    transition: opacity 0.25s ease, background 0.2s ease;
  }

  .entry::before {
    content: '';
    position: absolute;
    left: -1rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: transparent;
    transition: background 0.2s ease;
  }

  .entry:hover {
    background: rgba(203, 142, 66, 0.03);
  }

  .entry:hover::before {
    background: var(--accent-dim);
  }

  .entry.hidden {
    opacity: 0;
  }

  .entry:first-child {
    border-top: none;
  }

  .side {
    font-family: var(--mono);
    font-size: 0.7rem;
    line-height: 1.5;
    color: var(--ink-faint);
    padding-top: 0.35rem;
  }

  .side .date {
    display: block;
  }

  .side .topic {
    display: block;
    color: var(--accent-dim);
    margin-top: 0.3rem;
    transition: color 0.2s;
  }

  .side .topic:hover,
  .side .topic:focus-visible {
    color: var(--accent);
  }

  .side .topic:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 1px;
  }

  .entry h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.32rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: 0.45rem;
    transition: color 0.2s ease;
  }

  .entry a:hover h2,
  .entry a:focus-visible h2 {
    color: var(--accent);
  }

  .entry a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 1px;
  }

  .entry p {
    font-size: 1rem;
    color: var(--ink-dim);
    line-height: 1.5;
    max-width: 32rem;
  }

  @media (max-width: 560px) {
    .entry {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .side {
      padding-top: 0;
      display: flex;
      gap: 0.8rem;
      align-items: baseline;
    }

    .side .date {
      display: inline;
    }

    .side .topic {
      display: inline;
      margin-top: 0;
    }

    .side .topic::before {
      content: "· ";
    }
  }
</style>
