---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { vtName } from '../../lib/vt';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  );
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);

const { title, description, status, stack, year, links, accent } = project.data;

const STATUS_LABELS: Record<string, string> = {
  building: 'Building',
  planned: 'Planned',
  ongoing: 'Ongoing',
  shipped: 'Shipped',
};

const LINK_LABELS: Record<string, string> = {
  github: 'GitHub',
  demo: 'Demo',
};
function linkLabel(name: string) {
  return LINK_LABELS[name.toLowerCase()] ?? name;
}

const linkEntries = Object.entries(links).filter(([, url]) => url);
---

<BaseLayout title={title} description={description} image={`/og/projects/${project.id}.png`}>
  <div class="wrap">
    <article
      class:list={['project', { 'has-accent': accent }]}
      style={accent ? `--accent: ${accent}; --accent-dim: ${accent};` : undefined}
    >
      <header class="project-header halo">
        <a class="back fx" href="/projects">← Projects</a>
        <div class="ptop">
          <h1 style={`view-transition-name: ${vtName('proj', project.id)}`}>{title}</h1>
          <span class:list={['status', status]}>{STATUS_LABELS[status]}</span>
        </div>
        {stack.length > 0 && (
          <div class="stack">{stack.join(' · ')}</div>
        )}
        <p class="dek fx d2">{description}</p>

        {linkEntries.length > 0 && (
          <div class="links">
            {linkEntries.map(([name, url]) => (
              <a href={url} target="_blank" rel="noopener noreferrer">{linkLabel(name)}</a>
            ))}
          </div>
        )}
      </header>

      <TableOfContents headings={headings} />

      <div class="prose fx d2">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .project {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 3.5rem 0 5rem;
  }

  .back {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }

  .back:hover,
  .back:focus-visible {
    color: var(--accent);
  }

  .back:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 1px;
  }

  .ptop {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.7rem, 5vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 0.25rem;
  }

  .has-accent h1 {
    color: var(--accent);
  }

  .status {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.22rem 0.5rem;
    border-radius: 2px;
    border: 1px solid var(--line);
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .status.building {
    color: var(--accent);
    border-color: var(--accent-dim);
  }

  .status.ongoing {
    color: var(--status-sage);
    border-color: color-mix(in oklab, var(--status-sage) 40%, transparent);
  }

  .stack {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
    letter-spacing: 0.02em;
    margin-bottom: 0.75rem;
  }

  .dek {
    font-size: 1.1rem;
    color: var(--ink-dim);
    line-height: 1.5;
    margin-bottom: 0;
  }

  .links {
    margin-top: 1.5rem;
    display: flex;
    gap: 1.5rem;
  }

  .links a {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: var(--ink-dim);
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.15rem;
    transition: all 0.2s ease;
  }

  .links a:hover,
  .links a:focus-visible {
    color: var(--accent);
    border-color: var(--accent-dim);
  }

  .links a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 1px;
  }

</style>
