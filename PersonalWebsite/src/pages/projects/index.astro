---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = (
  await getCollection('projects', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true
  )
).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  if (a.data.order !== b.data.order) return b.data.order - a.data.order;
  return b.data.year - a.data.year;
});

const STATUS_LABELS: Record<string, string> = {
  building: 'Building',
  planned: 'Planned',
  ongoing: 'Ongoing',
  shipped: 'Shipped',
};
---

<BaseLayout title="Projects" description="Software, games, and experiments — things I'm building or have built.">
  <div class="wrap">
    <section class="projects-section">
      <div class="head">
        <h1>Projects</h1>
        <span class="meta">Building in public</span>
      </div>

      <div class="proj">
        {projects.map((project) => (
          <article
            class:list={['prow', { 'has-accent': project.data.accent }]}
            style={project.data.accent ? `--accent: ${project.data.accent}; --accent-dim: ${project.data.accent};` : undefined}
          >
            <div class="ptop">
              <a href={`/projects/${project.id}`}>
                <h2>{project.data.title}</h2>
              </a>
              <span class:list={['status', project.data.status]}>
                {STATUS_LABELS[project.data.status]}
              </span>
              {project.data.stack.length > 0 && (
                <span class="stack">{project.data.stack.join(' · ')}</span>
              )}
            </div>
            <p>{project.data.description}</p>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .projects-section {
    padding: 3.4rem 0;
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    gap: 1rem;
  }

  h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 6vw, 2.6rem);
    letter-spacing: 0.01em;
  }

  h1::after {
    content: '';
    display: block;
    width: 2.5rem;
    height: 2px;
    margin-top: 0.55rem;
    background: var(--accent);
    border-radius: 1px;
  }

  .meta {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

</style>
